void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) //Callback RX for FIFO0 (CAN1)
{
	if(hcan->Instance == CAN1)
	{

	CAN_RxHeaderTypeDef rxHeader;
	uint8_t rxData[8];

	// Read the received message
	if(HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &rxHeader, rxData) == HAL_OK)
	{

	  if (rxHeader.IDE == CAN_ID_STD){
			//Standard ID Received (From TSEB)
			if(rxHeader.StdId >= 18 && rxHeader.StdId <= 41)
			{
				uint8_t index = rxHeader.StdId - 18;
				for (int i = 0; i < rxHeader.DLC; i++)
				{
					tempData[index][i] = (char)rxData[i];
					tempDataInt[index][i] = rxData[i];
				}
			}
		}
	}
}
}

