void printTempData_DMA(void) {
    if (dma_tx_ready && huart5.gState == HAL_UART_STATE_READY) {
        dma_tx_ready = 0; // Kunci DMA

        int16_t len = 0;
        int16_t max_size = UART_TX_BUF_SIZE;
        const char* labels[] = {"1A", "2A", "3A", "4A", "1B", "2B", "3B", "4B"};

        // Loop untuk 8 modul suhu (1A sampai 4B)
        for (int m = 0; m < 8; m++) {
            len += snprintf(dma_tx_buffer + len, max_size - len, "TEMP DATA --- %s \n", labels[m]);

            int startRow = m * 3;
            int endRow = startRow + 3;

            for (int i = startRow; i < endRow; i++) {
                for (int j = 0; j < 8; j++) {
                    // Menggunakan matriks tempData tunggal hasil optimasi sebelumnya
                    len += snprintf(dma_tx_buffer + len, max_size - len, "%d - ", tempData[i][j]);
                }
            }
            len += snprintf(dma_tx_buffer + len, max_size - len, "\n--\n");
        }

        len += snprintf(dma_tx_buffer + len, max_size - len, "#\n\r");

        // Kirim seluruh string data suhu sekaligus lewat DMA
        if (len > 0) {
            if (HAL_UART_Transmit_DMA(&huart5, (uint8_t*)dma_tx_buffer, len) != HAL_OK) {
                dma_tx_ready = 1;
            }
        } else {
            dma_tx_ready = 1;
        }
    }
}

