//	sprintf (strNumber, "%.0f", fabs(currentC));

	// II. Extract the integer part (before the decimal)
	uint16_t currentCAN = (uint16_t)(fabs(current[0]) * 10.0f);


	// III. Extract tens and ones place
	uint8_t currentfirstByte = (uint8_t)(currentCAN >> 8);	  //MSB
	uint8_t currentsecondByte = (uint8_t)(currentCAN & 0xFF); //LSB

	CurrentData[0] = 0x06;
	CurrentData[1] = currentfirstByte;
	CurrentData[2] = currentsecondByte;
	CAN_TxHeaderTypeDef TxHeader;
	uint32_t TxMailbox;

	TxHeader.StdId = 0x12;
	TxHeader.ExtId = 0;
	TxHeader.IDE = CAN_ID_STD;
	TxHeader.RTR = CAN_RTR_DATA;
	TxHeader.DLC = 3;


	//CAN Transmit for the Current Data
//	HAL_CAN_AddTxMessage(&hcan2, &TxHeader, CurrentData, &TxMailbox);
	if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan2) == 0) {

	return 0;

	}



	if (HAL_CAN_AddTxMessage(&hcan2, &TxHeader, CurrentData, &TxMailbox) == HAL_OK) {

	return 1;

	}



	return 0;
}


void printCurrentData_DMA(void) {
    // Pastikan DMA siap dan hardware UART tidak sibuk
    if (dma_tx_ready && huart5.gState == HAL_UART_STATE_READY) {
        dma_tx_ready = 0; // Kunci flag DMA

        // Format string langsung ke dalam dma_tx_buffer
        // snprintf akan mengembalikan jumlah karakter yang berhasil ditulis
        int16_t len = snprintf(dma_tx_buffer, UART_TX_BUF_SIZE, "Current: %.2f A\r\n", current[1]);

        // Jika konversi berhasil, eksekusi transmisi DMA
        if (len > 0) {
            if (HAL_UART_Transmit_DMA(&huart5, (uint8_t*)dma_tx_buffer, len) != HAL_OK) {
                dma_tx_ready = 1; // Buka kunci jika hardware gagal inisialisasi
            }
        } else {
            dma_tx_ready = 1; // Buka kunci jika terjadi error pada snprintf
        }
    }
}

