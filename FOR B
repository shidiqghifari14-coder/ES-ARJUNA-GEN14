    uint32_t VtotalRaw = VtotalMV;

    VtotalData[0] = 0x16;                               // 0x15 A & 0x16 B
    VtotalData[1] = (uint8_t)(VtotalRaw >> 24);         // Byte1 MSB
    VtotalData[2] = (uint8_t)(VtotalRaw >> 16);         // Byte2
    VtotalData[3] = (uint8_t)(VtotalRaw >> 8);          // Byte3
    VtotalData[4] = (uint8_t)(VtotalRaw & 0xFF);        // Byte4 LSB

	CAN_TxHeaderTypeDef TxHeader;
	uint32_t TxMailbox;

	TxHeader.StdId = 0x12;
	TxHeader.ExtId = 0;
	TxHeader.IDE = CAN_ID_STD;
	TxHeader.RTR = CAN_RTR_DATA;
	TxHeader.DLC = 5;

    if(HAL_CAN_GetTxMailboxesFreeLevel(&hcan2) == 0){
        return 0;
    }

    if(HAL_CAN_AddTxMessage(&hcan2, &TxHeader, VtotalData, &TxMailbox) == HAL_OK){
        return 1;
    }

    return 0;
}

uint8_t CANTransmitCurrent(void){
