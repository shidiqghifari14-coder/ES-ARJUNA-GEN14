void filterVoltage(void){

	//Loop for each module for each interface (4 module each interface)
	for(int group = 0; group < 4; group++){
		int startIdx = group * 12;  //Series each module : 0-12, 12-24, 24-36, 36-48
		int endIdx = startIdx + 12;	//End the series at multiple of 12

		float minVal = cellVoltage[startIdx];
		float maxVal = cellVoltage[startIdx];
		float sum = 0;

		//Loop for read voltage of 12 series in each module
		for(int i = startIdx; i < endIdx; i++){
			float val = cellVoltage[i];
			if(val < minVal)
				minVal = val;
			if(val > maxVal)
				maxVal = val;
			sum += val;
		}

		minVoltage[group] = minVal;
		maxVoltage[group] = maxVal;
		avgVoltage[group] = sum / 12.0f;
	}
}

void filterTemp(void){
	//Loop for 8 module
	for(int i = 0; i < 8; i++){
//		float minTemp = 0;

//		float maxTemp = 0;
//		float sum = 0;

		int startRow = i * 3;		//Total temp data per module is 24
		int endRow = startRow + 3;

		int minVal = tempDataInt[startRow][0];
		int maxVal = tempDataInt[startRow][0];
		int sum = 0;

		//Loop for 24 data in each module
		for(int j = startRow; j < endRow; j++){
			for (int k = 0; k < 8; k++){
				int val = tempDataInt[j][k];

				if(val < minVal)
					minVal = val;
				if(val > maxVal)
					maxVal = val;
				sum += val;
			}
		}

		tempMin[i] = minVal;
		tempMax[i] = maxVal;
		avgTemp[i] = sum / 24.0f;
	}
}


